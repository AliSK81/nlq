# ---- LLM (user's OpenAI-compatible provider) ----
LLM_BASE_URL=https://your-provider/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1500
LLM_TIMEOUT=60

# ---- Query Agent ----
QUERY_AGENT_PORT=8000
DOCUMENT_INDEX_URL=http://document-index:8080
DOCUMENT_INDEX_API_VERSION=1
DOCUMENT_INDEX_TIMEOUT=120
OPENAI_COMPAT_MEMORY_WINDOW=5
AGENT_TOP_K=8
AGENT_MIN_SCORE=0.3
AGENT_MAX_REFINES=1
AGENT_MAX_CONTEXT_CHARS=12000
AGENT_MIN_CONFIDENCE=0.3

# ---- Document Index ----
PLATFORM_PORT=8080
EXTRACTOR=docling
DOCLING_URL=http://docling-serve:5001
TIKA_URL=http://tika:9998
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384
HYBRID_SEARCH=true
SPARSE_EMBEDDING_MODEL=Qdrant/bm25
RERANKER=fastembed
RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
RERANK_CANDIDATE_MULTIPLIER=4
CHUNK_TARGET_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=50
INGEST_WORKER_CONCURRENCY=2

# ---- Qdrant ----
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=document_chunks

# ---- Postgres ----
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/nlq
DATABASE_ENABLED=1

# ---- Observability (optional) ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=nlq-query-agent

# ---- Open WebUI ----
OPENAI_API_BASE_URL=http://query-agent:8000/v1
OPENAI_API_KEY=local-anything
